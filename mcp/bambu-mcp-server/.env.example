# Bambu Lab P1P MCP Server Configuration
# Copy this to .env or set as environment variables

# Your printer's IP address (find in router or printer network settings)
BAMBU_PRINTER_IP=192.168.1.100

# Access code from printer (Settings → Network → LAN Mode)
BAMBU_ACCESS_CODE=12345678

# Printer serial number (Settings → Device)
BAMBU_SERIAL_NUMBER=01P00A123456789
